# Required app config
CONTENTFUL_SPACE_ID=change-me
CONTENTFUL_ACCESS_TOKEN=change-me
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_DEFAULT_LOCALE=en-US

# Nginx / HTTPS
DOMAIN=api.example.com
