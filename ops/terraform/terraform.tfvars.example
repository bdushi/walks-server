# Required
compartment_ocid = "ocid1.compartment.oc1..change-me"
region           = "eu-frankfurt-1"

ssh_public_key = "ssh-ed25519 AAAA... yourkey"

# DNS / HTTPS (used by your app env file, not by Terraform directly)
domain = "api.example.com"

# Optional: pin the image OCID so future images don't force instance replacement.
# image_ocid = "ocid1.image.oc1...."

# Optional toggles
install_host_nginx_certbot = false
install_java               = false

# Sizing (Always Free ARM is typically VM.Standard.A1.Flex with up to 4 OCPUs / 24GB total free-tier)
shape = "VM.Standard.A1.Flex"
ocpus = 4
memory_in_gbs = 24

# Network
vcn_cidr    = "10.0.0.0/16"
subnet_cidr = "10.0.1.0/24"
